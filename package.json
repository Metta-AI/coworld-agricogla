{
  "name": "cogame-agricogla",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:coworld-manifest": "node scripts/build-coworld-manifest.mjs",
    "coworld": "tsx src/server/coworld-main.ts",
    "preview": "npm run build:web && tsx src/cli-serve.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "play": "tsx src/cli.ts",
    "serve": "tsx src/cli-serve.ts",
    "serve:llm": "AWS_REGION=${AWS_REGION:-us-west-2} tsx src/cli-serve.ts --agents llm,llm,llm,llm",
    "smoke": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3",
    "express": "^4.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@playwright/test": "^1.45",
    "@types/express": "^4.17",
    "@types/node": "^20",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@types/ws": "^8.5",
    "@vitejs/plugin-react": "^4.3",
    "tsx": "^4",
    "typescript": "^5.4",
    "vite": "^5.4",
    "vitest": "^1.6"
  }
}
