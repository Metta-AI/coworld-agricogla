# Discord Activity integration — copy to your server env (NOT committed).
# Discord routes mount only when these are set; absent = standalone web viewer.
# See docs/discord-activity.md for the one-time Developer Portal setup.

# From the Developer Portal → General Information
DISCORD_CLIENT_ID=
# From OAuth2 → Client Secret (server-only; never shipped to the browser)
DISCORD_CLIENT_SECRET=
# From General Information → Public Key (verifies interaction webhooks)
DISCORD_PUBLIC_KEY=

# Only for scripts/register-discord-commands.mjs (Bot → Token). Not needed at runtime.
DISCORD_BOT_TOKEN=
# Optional: register the slash command in one guild for instant availability.
DISCORD_GUILD_ID=

# DEV ONLY: fake the OAuth round-trip so the Activity can be driven in a plain
# browser at /?discord_shim=1&as=YourName . Never set this in production.
# DISCORD_DEV_SHIM=1
